PAYLOAD_SECRET=replace-with-a-long-random-secret

# === DB ===
# DB_DRIVER=sqlite|postgres   默认 sqlite
DB_DRIVER=sqlite
DATABASE_URL=file:./data.db
# 切到 postgres：
# DB_DRIVER=postgres
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/geoflow

NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# === Vector store ===
# 默认 unset：根据 DB_DRIVER 自动推断（sqlite → sqlite, postgres → pgvector）
# VECTOR_STORE=sqlite        # 嵌入式：向量直接落到 Payload 的 SQLite
# VECTOR_STORE=pgvector      # 复用 Payload 的 PostgreSQL，需要 pgvector 扩展
# PGVECTOR_URL=postgres://postgres:postgres@localhost:5432/geoflow
# PGVECTOR_DIM=384           # 与 EMBED_MODEL 维度对齐（MiniLM=384, BGE-base=768, OpenAI ada=1536）

# === LLM 模型（启动时若 ai-models 为空，自动 seed 一条）===
# 不设置 LLM_MODEL 则不会创建 LLM 配置（保留给用户从管理后台手动添加）
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_API_KEY=sk-xxx
# LLM_MODEL=deepseek-chat

# === Embedding 模型 ===
# Dev 默认：本地 transformers.js（首次自动下载 ~25MB 模型到 ~/.cache/huggingface）
EMBED_PROVIDER=local
EMBED_MODEL=Xenova/all-MiniLM-L6-v2
# 走外部 API（prod 推荐）：
# EMBED_PROVIDER=openai-compatible
# EMBED_BASE_URL=https://api.openai.com/v1
# EMBED_API_KEY=sk-xxx
# EMBED_MODEL=text-embedding-3-small

# === Jobs ===
# JOBS_AUTORUN=false  # 关闭内置 cron worker（prod 用独立 worker.ts）
